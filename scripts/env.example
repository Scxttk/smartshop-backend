# smartshop Nightly-Konfiguration
#
# Diese Datei nach ~/.config/smartshop/env kopieren und Werte eintragen.
# NIEMALS mit echten Werten einchecken! Empfohlen: chmod 600 ~/.config/smartshop/env
#
#   mkdir -p ~/.config/smartshop
#   cp scripts/env.example ~/.config/smartshop/env
#   chmod 600 ~/.config/smartshop/env

# Pflicht: Postleitzahl für Marktsuche und push --region
ZIP=50667

# Pflicht: Supabase-Projekt-URL und Service-Role-Key (nicht der anon key!)
SUPABASE_URL=https://xyzxyzxyz.supabase.co
SUPABASE_SERVICE_KEY=eyJ...dein-service-role-key...

# Optional: Pfad zur SQLite-Datenbank
# DB=$HOME/.local/share/smartshop/smartshop.db

# Optional: Pfad zum smartshop-Binary (Standard: PATH, dann ~/.cargo/bin/smartshop)
# SMARTSHOP_BIN=$HOME/.cargo/bin/smartshop

# Optional: Rewe-Client-Zertifikat (siehe docs/rewe-cert.md).
# Ohne diese beiden läuft der Lauf trotzdem, Rewe schlägt dann fehl.
# REWE_CERT=$HOME/.config/smartshop/rewe-cert.pem
# REWE_KEY=$HOME/.config/smartshop/rewe-private.key

# Optional: ntfy.sh-Topic für Benachrichtigungen bei Fehlern und
# Watchlist-Treffern. Leer/auskommentiert = keine Benachrichtigungen.
# NTFY_TOPIC=mein-geheimes-smartshop-topic
